@model IEnumerable<mym.Models.Forum>

@{
    ViewData["Title"] = "Tüm Forumlara Gözat";
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8">
        <h1 class="text-4xl font-bold text-gray-800 mb-2">
            <i class="fas fa-comments text-indigo-600 mr-3"></i>Forum Kategorileri
        </h1>
        <p class="text-gray-600">İlginizi çeken kategorileri seçerek konuları gözleyin ve tartışmalara katılın</p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
        @foreach (var forum in Model)
        {
            <div class="bg-white border-2 border-indigo-200 rounded-lg shadow-md hover:shadow-xl hover:border-indigo-600 transition-all duration-300 overflow-hidden group cursor-pointer">
                <a asp-action="Details" asp-route-id="@forum.Id" class="no-underline">
                    <div class="bg-gradient-to-r from-indigo-500 to-indigo-600 p-6 text-white">
                        <div class="flex items-center justify-between mb-3">
                            <i class="@forum.Icon text-4xl opacity-80"></i>
                            <span class="bg-indigo-400 px-3 py-1 rounded-full text-sm font-bold">@forum.TopicCount Konu</span>
                        </div>
                        <h3 class="text-2xl font-bold group-hover:text-indigo-100 transition-colors">@forum.Title</h3>
                    </div>
                    <div class="p-6">
                        <p class="text-gray-600 mb-4">@forum.Description</p>
                        <div class="flex items-center justify-between text-sm text-gray-500">
                            <span><i class="fas fa-comments mr-2"></i>@forum.CommentCount Yorum</span>
                            <span><i class="fas fa-calendar-alt mr-2"></i>@forum.CreatedDate.ToString("dd MMM yyyy")</span>
                        </div>
                    </div>
                </a>
            </div>
        }
    </div>

    @if (!Model.Any())
    {
        <div class="text-center py-12">
            <i class="fas fa-inbox text-6xl text-gray-300 mb-4"></i>
            <p class="text-gray-500 text-lg">Henüz forum bulunamadı</p>
        </div>
    }
</div>
