@model mym.Models.Forum

@{
    ViewData["Title"] = $"{Model?.Title} - Forum";
    var canCreateTopic = (ViewBag.CanCreateTopic as bool?) == true;
}

<div class="max-w-7xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <div class="mb-8 bg-gradient-to-r from-indigo-500 to-indigo-600 text-white p-6 rounded-lg">
        <div class="flex items-center justify-between">
            <div>
                <div class="flex items-center mb-3">
                    <i class="@Model?.Icon text-4xl opacity-80 mr-4"></i>
                    <div>
                        <h1 class="text-4xl font-bold">@Model?.Title</h1>
                        <p class="text-indigo-100 mt-2">@Model?.Description</p>
                    </div>
                </div>
            </div>
            <div class="text-right">
                <div class="text-3xl font-bold">@Model?.TopicCount</div>
                <p class="text-indigo-100">Konu</p>
            </div>
        </div>
    </div>

    @if (TempData["Message"] != null)
    {
        <div class="mb-6 rounded-lg border border-amber-200 bg-amber-50 px-4 py-3 text-amber-800">
            @TempData["Message"]
        </div>
    }

    <div class="mb-6 flex flex-wrap gap-4">
        @if (User.Identity?.IsAuthenticated != true)
        {
            <a asp-controller="Account" asp-action="Login" class="inline-block bg-indigo-600 text-white hover:bg-indigo-700 font-bold py-2 px-6 rounded-lg transition-all duration-300">
                <i class="fas fa-right-to-bracket mr-2"></i>Giris Yap ve Konu Ac
            </a>
        }
        else if (!canCreateTopic)
        {
            <span class="inline-block bg-amber-100 text-amber-800 font-semibold py-2 px-6 rounded-lg">
                Hesabin onaylanmadan yeni konu acamazsin.
            </span>
        }
        else
        {
            <a asp-controller="Topic" asp-action="Create" asp-route-forumId="@Model?.Id" class="inline-block bg-indigo-600 text-white hover:bg-indigo-700 font-bold py-2 px-6 rounded-lg transition-all duration-300 transform hover:scale-105">
                <i class="fas fa-plus mr-2"></i>Yeni Konu Olustur
            </a>
        }

        <a asp-controller="Forum" asp-action="Index" class="inline-block bg-gray-300 text-gray-700 hover:bg-gray-400 font-bold py-2 px-6 rounded-lg transition-all duration-300">
            <i class="fas fa-arrow-left mr-2"></i>Forumlara Geri Don
        </a>
    </div>

    <div class="space-y-4">
        @if (Model?.Topics != null && Model.Topics.Any())
        {
            @foreach (var topic in Model.Topics.OrderByDescending(t => t.CreatedDate))
            {
                <div class="bg-white p-6 rounded-lg shadow-md hover:shadow-lg transition-shadow duration-300 border-l-4 border-indigo-600">
                    <a asp-controller="Topic" asp-action="Details" asp-route-id="@topic.Id" class="no-underline hover:no-underline">
                        <div class="flex items-start justify-between mb-3">
                            <div class="flex-1">
                                <h3 class="text-xl font-bold text-gray-800 hover:text-indigo-600 cursor-pointer transition-colors">
                                    @topic.Title
                                </h3>
                                <p class="text-sm text-gray-500 mt-2">
                                    <i class="fas fa-user mr-2"></i><span class="font-semibold">@topic.AuthorName</span>
                                    <i class="fas fa-calendar mr-2 ml-4"></i>@topic.CreatedDate.ToString("dd MMM yyyy HH:mm")
                                </p>
                            </div>
                            <span class="bg-indigo-100 text-indigo-700 px-3 py-1 rounded-full text-sm font-bold whitespace-nowrap ml-4">
                                @(topic.CommentCount > 0 ? $"{topic.CommentCount} Yorum" : "Yeni")
                            </span>
                        </div>
                        <p class="text-gray-600 mb-4 line-clamp-2">@topic.Content</p>
                    </a>
                    <div class="flex items-center justify-between text-sm text-gray-500">
                        <div class="flex gap-6">
                            <span><i class="fas fa-comments mr-2"></i>@topic.CommentCount Yorum</span>
                            <span><i class="fas fa-eye mr-2"></i>@topic.ViewCount Goruntuleme</span>
                        </div>
                        <div class="flex items-center gap-2">
                            @if (topic.CommentCount == 0)
                            {
                                <span class="bg-yellow-100 text-yellow-700 px-2 py-1 rounded text-xs">Cevap Bekliyor</span>
                            }
                            else
                            {
                                <span class="bg-green-100 text-green-700 px-2 py-1 rounded text-xs">Cevaplandi</span>
                            }
                        </div>
                    </div>
                </div>
            }
        }
        else
        {
            <div class="text-center py-12 bg-gray-50 rounded-lg">
                <i class="fas fa-inbox text-6xl text-gray-300 mb-4"></i>
                <p class="text-gray-500 text-lg">Bu forumda henuz konu yok.</p>
            </div>
        }
    </div>
</div>
