@{
    ViewData["Title"] = "Misafir Hesabı Oluştur";
}

<div class="mx-auto max-w-xl">
    <div class="rounded-2xl border border-slate-200 bg-white p-6 shadow-sm">
        <h2 class="text-lg font-semibold text-slate-900">Misafir Hesabı Oluştur</h2>
        <p class="mt-2 text-sm text-slate-500">Hızlıca bir misafir hesabı oluşturarak siteyi 2 gün süreyle misafir olarak kullanabilirsiniz. Hesap süresi dolduğunda otomatik silinecektir.</p>

        <form asp-action="CreateGuestPost" method="post" class="mt-6">
            @Html.AntiForgeryToken()
            <div class="flex gap-3">
                <button type="submit" class="inline-flex items-center gap-2 rounded-md bg-amber-600 px-4 py-2 text-sm font-medium text-white hover:bg-amber-700">Misafir Hesabı Oluştur</button>
                <a asp-action="Create" class="inline-flex items-center gap-2 rounded-md border border-slate-200 px-3 py-2 text-sm text-slate-700 hover:bg-slate-50">Normal Kayıt</a>
            </div>
        </form>
    </div>
</div>
