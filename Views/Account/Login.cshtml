@model mym.Models.AccountLoginModel
@{
    ViewData["Title"] = "Giriş Yap";
    Layout = "_LayoutAccount";
}

<section class="min-h-screen bg-gray-50 py-12 px-4 bg-stone-100">
    <div class="container mx-auto flex justify-center">
        <div class="w-full max-w-md">
            <div class="bg-white rounded-lg shadow-lg">
                <div class="p-8">
                    <div class="text-center mb-8">
                        <div class="inline-flex items-center justify-center w-16 h-16 bg-blue-100 rounded-full mb-4">
                            <svg class="w-8 h-8 text-blue-600" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"></path>
                            </svg>
                        </div>
                        <h2 class="text-3xl font-bold text-gray-900 mb-2">Hoş Geldiniz</h2>
                        <p class="text-sm text-gray-600">Hesabınıza giriş yapın</p>
                    </div>

                    <form method="post" novalidate>
                        @if (!ViewData.ModelState.IsValid && ViewData.ModelState.ErrorCount > 0)
                        {
                            <div asp-validation-summary="All" class="bg-red-50 border border-red-200 text-red-600 px-4 py-3 rounded mb-4"></div>
                        }
                        
                        <div class="mb-5">
                            <label asp-for="Username" class="block text-sm font-medium text-gray-700 mb-2"></label>
                            <input asp-for="Username" 
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                                   placeholder="Kullanıcı adınızı girin">
                            <span asp-validation-for="Username" class="text-red-500 text-sm mt-1 block"></span>
                        </div>
                        
                        <div class="mb-5">
                            <label asp-for="Password" class="block text-sm font-medium text-gray-700 mb-2"></label>
                            <input asp-for="Password" 
                                   type="password"
                                   class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:ring-2 focus:ring-blue-500 focus:border-transparent outline-none transition"
                                   placeholder="Şifrenizi girin">
                            <span asp-validation-for="Password" class="text-red-500 text-sm mt-1 block"></span>
                        </div>

                        <div class="flex items-center justify-between mb-6">
                            <div class="flex items-center">
                            <input asp-for="RememberMe"
                                       id="rememberMe"
                                       class="w-4 h-4 text-blue-600 border-gray-300 rounded focus:ring-2 focus:ring-blue-500 cursor-pointer">
                                <label for="rememberMe" class="ml-2 text-sm text-gray-700 cursor-pointer">
                                    Beni hatırla
                                </label>
                            </div>
                            <a asp-action="ForgotPassword" 
                               asp-controller="Account" 
                               class="text-sm text-blue-600 hover:text-blue-800 transition">
                                Şifremi unuttum?
                            </a>
                        </div>

                        <button type="submit" 
                                class="w-full bg-blue-600 hover:bg-blue-700 text-white font-semibold py-3 px-6 rounded-lg transition duration-200 ease-in-out transform hover:scale-[1.02] focus:outline-none focus:ring-2 focus:ring-blue-500 focus:ring-offset-2 mb-2">
                            Giriş Yap
                        </button>

                        @* ------------------------------------------------------Hesap Oluştur------------------------------------------------ *@
                        <div class="mt-6 pt-6 border-t border-gray-200">
                            <p class="text-center text-sm text-gray-600">
                                Henüz hesabın yok mu? 
                                <a asp-action="Create" 
                                   asp-controller="Account" 
                                   class="font-semibold text-blue-600 hover:text-blue-800 transition">
                                    Hesap Oluştur
                                </a>
                            </p>
                        </div>
                        @* ------------------------------------------------------------------------------------------------------------ *@
                        <div class="mt-6 pt-6 border-t border-gray-200">
                            <p class="text-center text-sm text-gray-600">
                                Misafir Hesabı ister misin? 
                                <a asp-action="Create" 
                                   asp-controller="Account" 
                                   class="font-semibold text-blue-600 hover:text-blue-800 transition">
                                    Misafir Hesabı Oluştur
                                </a>
                            </p>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>
