@using mym.Services
@inject IThemeSettingsService ThemeSettingsService
@{
    var theme = await ThemeSettingsService.GetCurrentAsync();
    var bodyClass = theme.IsDarkMode ? "theme-dark" : "theme-light";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - Admin</title>
    <meta name="robots" content="noindex,nofollow,noarchive" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="shortcut icon" href="img/maybering.png" type="image/x-icon">
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mym.styles.css" asp-append-version="true" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
</head>
<body class="min-h-screen @bodyClass" style="--theme-primary:@theme.PrimaryColor;--theme-secondary:@theme.SecondaryColor;--theme-accent:@theme.AccentColor;--theme-bg:@theme.BackgroundColor;--theme-surface:@theme.SurfaceColor;--theme-text:@theme.TextColor; background:var(--theme-bg); color:var(--theme-text);">
    <div class="min-h-screen lg:grid lg:grid-cols-[260px_1fr]">
        <aside class="hidden lg:flex lg:flex-col border-r border-slate-200 text-white" style="background:linear-gradient(180deg,var(--theme-secondary),var(--theme-primary));">
            <div class="px-6 py-6 border-b border-white/10">
                <a asp-controller="Home" asp-action="Index" class="text-xl font-bold tracking-wide">
                    UniYORUM Admin Paneli
                </a>
            </div>
            <nav class="p-4 space-y-2">
                <a asp-controller="User" asp-action="Index" class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium hover:bg-white/10 transition">
                    <i class="fa-solid fa-users"></i>
                    Kullanicilar
                </a>
                <a asp-controller="AdminActivity" asp-action="Index" class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium hover:bg-white/10 transition">
                    <i class="fa-solid fa-chart-line"></i>
                    Aktivite
                </a>
                <a asp-controller="SiteSettings" asp-action="Index" class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium hover:bg-white/10 transition">
                    <i class="fa-solid fa-gear"></i>
                    Site Ayarlari
                </a>
                <a asp-controller="Role" asp-action="Index" class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium hover:bg-white/10 transition">
                    <i class="fa-solid fa-shield-halved"></i>
                    Roller
                </a>
                <a asp-controller="Theme" asp-action="Index" class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium hover:bg-white/10 transition">
                    <i class="fa-solid fa-palette"></i>
                    Tema Ayarlari
                </a>
                <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium hover:bg-white/10 transition">
                    <i class="fa-solid fa-house"></i>
                    Siteye Don
                </a>
            </nav>
        </aside>

        <div class="flex min-h-screen flex-col">
                        <a asp-controller="AdminActivity" asp-action="Index" class="flex items-center gap-3 rounded-lg px-4 py-3 text-sm font-medium hover:bg-white/10 transition">
                            <i class="fa-solid fa-chart-line"></i>
                            Aktivite
                        </a>
            <header class="sticky top-0 z-30 border-b border-slate-200 backdrop-blur" style="background:color-mix(in srgb, var(--theme-surface) 92%, transparent);">
                <div class="mx-auto flex max-w-7xl items-center justify-between gap-3 px-4 py-4 sm:px-6 lg:px-8">
                    <div class="flex items-center gap-3">
                        <button id="mobile-nav-toggle" type="button" class="lg:hidden inline-flex items-center justify-center h-10 w-10 rounded-md border border-slate-200 text-slate-600 hover:bg-slate-100">
                            <i class="fa-solid fa-bars"></i>
                        </button>
                        <div>
                            <h1 class="text-lg font-semibold">@ViewData["Title"]</h1>
                            <p class="text-xs text-slate-500">Yonetim paneli</p>
                        </div>
                    </div>
                    <div class="flex items-center gap-2">
                        <div class="relative">
                            <button id="admin-notification-btn" type="button" class="relative inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-600 hover:bg-slate-100 transition">
                                <i class="fa-solid fa-bell"></i>
                                Bildirimler
                                <span id="admin-notification-badge" class="hidden min-w-5 rounded-full bg-rose-600 px-1.5 py-0.5 text-center text-xs font-semibold text-white"></span>
                            </button>
                            <div id="admin-notification-menu" class="absolute right-0 mt-2 hidden w-80 rounded-xl border border-slate-200 bg-white shadow-lg">
                                <div class="flex items-center justify-between border-b border-slate-200 px-4 py-3">
                                    <span class="text-sm font-semibold text-slate-800">Son Bildirimler</span>
                                    <button id="mark-notifications-read" type="button" class="text-xs font-medium text-indigo-600 hover:text-indigo-800">Okundu isaretle</button>
                                </div>
                                <div id="admin-notification-list" class="max-h-80 overflow-y-auto p-2 text-sm text-slate-600"></div>
                            </div>
                        </div>
                        <a asp-controller="Home" asp-action="Index" class="inline-flex items-center gap-2 rounded-lg border border-slate-200 px-3 py-2 text-sm text-slate-600 hover:bg-slate-100 transition">
                            <i class="fa-solid fa-arrow-left"></i>
                            Ana sayfa
                        </a>
                    </div>
                </div>
            </header>

            <!-- Mobile nav (hidden on lg and up) -->
            <div id="mobile-admin-nav" class="lg:hidden hidden border-b border-slate-200 bg-white">
                <div class="px-4 py-3">
                    <nav class="space-y-2">
                        <a asp-controller="User" asp-action="Index" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium hover:bg-slate-50">
                            <i class="fa-solid fa-users"></i>
                            Kullanicilar
                        </a>
                        <a asp-controller="Role" asp-action="Index" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium hover:bg-slate-50">
                            <i class="fa-solid fa-shield-halved"></i>
                            Roller
                        </a>
                        <a asp-controller="Theme" asp-action="Index" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium hover:bg-slate-50">
                            <i class="fa-solid fa-palette"></i>
                            Tema Ayarlari
                        </a>
                        <a asp-controller="SiteSettings" asp-action="Index" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium hover:bg-slate-50">
                            <i class="fa-solid fa-gear"></i>
                            Site Ayarlari
                        </a>
                        <a asp-controller="Home" asp-action="Index" class="flex items-center gap-3 rounded-lg px-3 py-2 text-sm font-medium hover:bg-slate-50">
                            <i class="fa-solid fa-house"></i>
                            Siteye Don
                        </a>
                    </nav>
                </div>
            </div>

            <main class="mx-auto w-full max-w-7xl flex-1 px-4 py-6 sm:px-6 lg:px-8">
                @await Html.PartialAsync("partials/admin/_Message")
                @RenderBody()
            </main>
        </div>
    </div>

    <form id="notification-read-form" class="hidden" asp-controller="User" asp-action="MarkNotificationsRead" method="post">
        @Html.AntiForgeryToken()
    </form>

    <script>
        document.addEventListener("DOMContentLoaded", function () {
            const alerts = document.querySelectorAll(".alert");
            const closeButtons = document.querySelectorAll(".alert-close-btn");
            const notificationBtn = document.getElementById("admin-notification-btn");
            const notificationMenu = document.getElementById("admin-notification-menu");
            const notificationList = document.getElementById("admin-notification-list");
            const notificationBadge = document.getElementById("admin-notification-badge");
            const markReadBtn = document.getElementById("mark-notifications-read");
            const readFormToken = document.querySelector("#notification-read-form input[name='__RequestVerificationToken']");
            const mobileToggle = document.getElementById("mobile-nav-toggle");
            const mobileNav = document.getElementById("mobile-admin-nav");

            alerts.forEach(function (alert) {
                setTimeout(function () { closeAlert(alert); }, 5000);
            });

            closeButtons.forEach(function (button) {
                button.addEventListener("click", function () {
                    closeAlert(button.closest(".alert"));
                });
            });

            function closeAlert(alertElement) {
                if (!alertElement) return;
                alertElement.style.opacity = "0";
                setTimeout(function () { alertElement.remove(); }, 300);
            }

            async function refreshNotifications() {
                try {
                    const response = await fetch("@Url.Action("Notifications", "User")", { cache: "no-store" });
                    if (!response.ok) return;
                    const data = await response.json();

                    const unread = data.unreadCount || 0;
                    if (unread > 0) {
                        notificationBadge.textContent = unread;
                        notificationBadge.classList.remove("hidden");
                    } else {
                        notificationBadge.classList.add("hidden");
                    }

                    const items = data.items || [];
                    if (items.length === 0) {
                        notificationList.innerHTML = '<div class="px-2 py-3 text-xs text-slate-500">Bildirim yok.</div>';
                        return;
                    }

                    notificationList.innerHTML = items.map(function (item) {
                        const typeClass = item.type === "danger"
                            ? "text-rose-600"
                            : item.type === "warning"
                                ? "text-amber-600"
                                : item.type === "success"
                                    ? "text-emerald-600"
                                    : "text-indigo-600";

                        return '<div class="rounded-lg px-2 py-2 hover:bg-slate-50">'
                            + '<div class="text-xs font-semibold ' + typeClass + '">' + (item.title || '') + '</div>'
                            + '<div class="text-xs text-slate-600">' + (item.message || '') + '</div>'
                            + '<div class="mt-1 text-[11px] text-slate-400">' + (item.createdAt || '') + '</div>'
                            + '</div>';
                    }).join('');
                } catch {
                }
            }

            if (notificationBtn) {
                notificationBtn.addEventListener("click", function () {
                    notificationMenu.classList.toggle("hidden");
                });
            }

            if (markReadBtn) {
                markReadBtn.addEventListener("click", async function () {
                    try {
                        await fetch("@Url.Action("MarkNotificationsRead", "User")", {
                            method: "POST",
                            headers: {
                                "RequestVerificationToken": readFormToken ? readFormToken.value : ""
                            }
                        });
                        await refreshNotifications();
                    } catch {
                    }
                });
            }

            if (mobileToggle && mobileNav) {
                mobileToggle.addEventListener("click", function (e) {
                    e.stopPropagation();
                    mobileNav.classList.toggle("hidden");
                });

                document.addEventListener("click", function (e) {
                    if (!mobileNav.contains(e.target) && !mobileToggle.contains(e.target)) {
                        mobileNav.classList.add("hidden");
                    }
                });
            }

            document.addEventListener("click", function (e) {
                if (!notificationMenu || !notificationBtn) return;
                if (!notificationMenu.contains(e.target) && !notificationBtn.contains(e.target)) {
                    notificationMenu.classList.add("hidden");
                }
            });

            refreshNotifications();
            setInterval(refreshNotifications, 10000);
        });
    </script>

    @await RenderSectionAsync("Scripts", required: false)
</body>
</html>
