@using mym.Services
@inject IThemeSettingsService ThemeSettingsService
@{
    var theme = await ThemeSettingsService.GetCurrentAsync();
    var bodyClass = theme.IsDarkMode ? "theme-dark" : "theme-light";
    var metaTitle = (ViewData["Title"]?.ToString() ?? "MyM") + " - MyM";
    var metaDescription = ViewData["MetaDescription"]?.ToString()
        ?? "MyM universite ogrencileri icin forum, bilgi paylasimi ve topluluk platformudur.";
    var canonicalUrl = $"{Context.Request.Scheme}://{Context.Request.Host}{Context.Request.Path}";
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@metaTitle</title>
    <meta name="description" content="@metaDescription" />
    <meta name="robots" content="index,follow,max-image-preview:large" />
    <link rel="canonical" href="@canonicalUrl" />
    <meta property="og:type" content="website" />
    <meta property="og:locale" content="tr_TR" />
    <meta property="og:title" content="@metaTitle" />
    <meta property="og:description" content="@metaDescription" />
    <meta property="og:url" content="@canonicalUrl" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content="@metaTitle" />
    <meta name="twitter:description" content="@metaDescription" />
    <script type="importmap"></script>
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    <link rel="stylesheet" href="~/mym.styles.css" asp-append-version="true" />
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <link rel="shortcut icon" href="img/maybering.png" type="image/x-icon">
</head>
<body class="min-h-screen flex flex-col @bodyClass" style="--theme-primary:@theme.PrimaryColor;--theme-secondary:@theme.SecondaryColor;--theme-accent:@theme.AccentColor;--theme-bg:@theme.BackgroundColor;--theme-surface:@theme.SurfaceColor;--theme-text:@theme.TextColor; background:var(--theme-bg); color:var(--theme-text);">
    <header>
        @await Html.PartialAsync("partials/site/_Navbar.cshtml")
    </header>
    <div class="flex-1">
        <main role="main" class="pb-6">
            @RenderBody()
        </main>
    </div>

    <div id="cookie-consent" class="fixed bottom-4 left-4 right-4 z-50 hidden rounded-xl border border-slate-200 bg-white p-4 shadow-xl sm:left-auto sm:right-6 sm:w-[420px]">
        <p class="text-sm text-slate-700">
            Zorunlu cerezler hizmetin calismasi icin kullanilir. Ayrintilar icin
            <a asp-controller="Home" asp-action="CookiePolicy" class="font-semibold text-indigo-600 hover:text-indigo-800">Cerez Politikasi</a> sayfasini inceleyin.
        </p>
        <div class="mt-3 flex gap-2">
            <button id="cookie-accept" type="button" class="rounded-lg bg-indigo-600 px-3 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Kabul Et</button>
            <button id="cookie-reject" type="button" class="rounded-lg border border-slate-300 px-3 py-2 text-sm font-semibold text-slate-700 hover:bg-slate-50">Reddet</button>
        </div>
    </div>

    @await Html.PartialAsync("partials/site/_Footer.cshtml")
    <script src="~/lib/jquery/dist/jquery.min.js"></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
    <script src="~/js/site.js" asp-append-version="true"></script>
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        const menuButton = document.getElementById('mobile-menu-btn');
        if (menuButton) {
            menuButton.addEventListener('click', function () {
                const menu = document.getElementById('mobile-menu');
                if (menu) {
                    menu.classList.toggle('hidden');
                }
            });
        }

        document.querySelectorAll('#mobile-menu a').forEach(function (link) {
            link.addEventListener('click', function () {
                const menu = document.getElementById('mobile-menu');
                if (menu) {
                    menu.classList.add('hidden');
                }
            });
        });

        const consentBox = document.getElementById('cookie-consent');
        const acceptBtn = document.getElementById('cookie-accept');
        const rejectBtn = document.getElementById('cookie-reject');
        const consent = localStorage.getItem('cookie_consent');

        if (!consent && consentBox) {
            consentBox.classList.remove('hidden');
        }

        function closeConsent(value) {
            localStorage.setItem('cookie_consent', value);
            if (consentBox) {
                consentBox.classList.add('hidden');
            }
        }

        if (acceptBtn) {
            acceptBtn.addEventListener('click', function () { closeConsent('accepted'); });
        }

        if (rejectBtn) {
            rejectBtn.addEventListener('click', function () { closeConsent('rejected'); });
        }
    </script>
</body>
</html>
