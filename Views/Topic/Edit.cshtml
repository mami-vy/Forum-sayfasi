@model mym.Models.Topic

@{
    ViewData["Title"] = "Konuyu Düzenle";
}

<div class="max-w-4xl mx-auto px-4 sm:px-6 lg:px-8 py-8">
    <!-- Back Button -->
    <div class="mb-6">
        <a asp-action="Details" asp-route-id="@Model?.Id" class="inline-block bg-gray-300 text-gray-700 hover:bg-gray-400 font-bold py-2 px-4 rounded-lg transition-all duration-300">
            <i class="fas fa-arrow-left mr-2"></i>Geri Dön
        </a>
    </div>

    <!-- Form Card -->
    <div class="bg-white rounded-lg shadow-md p-8">
        <h1 class="text-3xl font-bold text-gray-800 mb-6">
            <i class="fas fa-edit text-indigo-600 mr-2"></i>Konuyu Düzenle
        </h1>

        <form asp-action="Edit" method="post" class="space-y-6">
            <input type="hidden" asp-for="Id" />
            <input type="hidden" asp-for="ForumId" />
            <input type="hidden" asp-for="CreatedDate" />

            @if (!ViewData.ModelState.IsValid)
            {
                <div class="bg-red-50 border border-red-200 rounded-lg p-4">
                    @foreach (var modelState in ViewData.ModelState.Values)
                    {
                        @foreach (var error in modelState.Errors)
                        {
                            <p class="text-red-700">
                                <i class="fas fa-exclamation-circle mr-2"></i>@error.ErrorMessage
                            </p>
                        }
                    }
                </div>
            }

            <!-- Title -->
            <div>
                <label asp-for="Title" class="block text-gray-700 font-semibold mb-2">Konu Başlığı</label>
                <input asp-for="Title" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <span asp-validation-for="Title" class="text-red-600 text-sm"></span>
            </div>

            <!-- Content -->
            <div>
                <label asp-for="Content" class="block text-gray-700 font-semibold mb-2">Konu İçeriği</label>
                <textarea asp-for="Content" rows="8" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500"></textarea>
                <span asp-validation-for="Content" class="text-red-600 text-sm"></span>
            </div>

            <!-- Author Name -->
            <div>
                <label asp-for="AuthorName" class="block text-gray-700 font-semibold mb-2">Adınız</label>
                <input asp-for="AuthorName" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <span asp-validation-for="AuthorName" class="text-red-600 text-sm"></span>
            </div>

            <!-- Author Email -->
            <div>
                <label asp-for="AuthorEmail" class="block text-gray-700 font-semibold mb-2">E-posta</label>
                <input asp-for="AuthorEmail" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg focus:outline-none focus:ring-2 focus:ring-indigo-500" />
                <span asp-validation-for="AuthorEmail" class="text-red-600 text-sm"></span>
            </div>

            <!-- Buttons -->
            <div class="flex gap-4 pt-6 border-t border-gray-200">
                <button type="submit" class="flex-1 bg-indigo-600 text-white hover:bg-indigo-700 font-bold py-3 px-6 rounded-lg transition-all duration-300">
                    <i class="fas fa-save mr-2"></i>Değişiklikleri Kaydet
                </button>
                <a asp-action="Details" asp-route-id="@Model?.Id" class="flex-1 bg-gray-300 text-gray-700 hover:bg-gray-400 font-bold py-3 px-6 rounded-lg transition-all duration-300 text-center">
                    <i class="fas fa-times mr-2"></i>İptal
                </a>
            </div>
        </form>
    </div>
</div>
