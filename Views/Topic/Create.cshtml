@model mym.Models.Topic

@{
    ViewData["Title"] = "Yeni Konu Olustur";
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="mb-6">
        <a asp-controller="Forum" asp-action="Details" asp-route-id="@ViewBag.ForumId" class="inline-flex items-center gap-2 bg-gray-100 text-gray-700 hover:bg-gray-200 px-3 py-2 rounded-lg shadow-sm transition">
            <i class="fas fa-arrow-left"></i>
            <span class="font-medium">Geri Dön</span>
        </a>
    </div>

    <div class="bg-white rounded-2xl shadow-lg p-8 sm:p-10">
        <div class="sm:flex sm:items-start sm:justify-between">
            <div>
                <h1 class="text-2xl sm:text-3xl font-extrabold text-gray-900 mb-1">
                    <i class="fas fa-pen-fancy text-indigo-600 mr-2"></i>Yeni Konu Oluştur
                </h1>
                <p class="text-sm text-gray-600">Konu sadece admin tarafından onaylanmış hesaplarla paylaşılabilir.</p>
            </div>
            <div class="mt-4 sm:mt-0">
                <span class="inline-flex items-center px-3 py-1 rounded-full bg-indigo-50 text-indigo-700 text-sm">Forum ID: @ViewBag.ForumId</span>
            </div>
        </div>

        <form asp-action="Create" asp-route-forumId="@ViewBag.ForumId" method="post" novalidate class="mt-8 space-y-6">
            @if (!ViewData.ModelState.IsValid)
            {
                <div class="rounded-lg bg-red-50 border border-red-100 p-4">
                    <div class="flex items-start gap-3">
                        <i class="fas fa-exclamation-triangle text-red-600 mt-1"></i>
                        <div>
                            <p class="font-semibold text-red-700">Lütfen form hatalarını düzeltin:</p>
                            <ul class="mt-2 list-disc list-inside text-red-600 text-sm">
                                @foreach (var modelState in ViewData.ModelState.Values)
                                {
                                    @foreach (var error in modelState.Errors)
                                    {
                                        <li>@error.ErrorMessage</li>
                                    }
                                }
                            </ul>
                        </div>
                    </div>
                </div>
            }

            <div>
                <label asp-for="Title" class="block text-sm font-medium text-gray-700">
                    Konu Başlığı <span class="text-red-600">*</span>
                </label>
                <input asp-for="Title" placeholder="Açık ve anlaşılır bir başlık yazın" autofocus
                       class="mt-2 w-full rounded-lg px-4 py-2 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 @(ViewData.ModelState["Title"]?.Errors.Count > 0 ? "border-red-500 ring-red-50" : "border border-gray-200")" />
                <span asp-validation-for="Title" class="text-sm text-red-600 mt-2 block"></span>
            </div>

            <div>
                <label asp-for="Content" class="block text-sm font-medium text-gray-700">
                    Konu İçeriği <span class="text-red-600">*</span>
                </label>
                <textarea asp-for="Content" placeholder="Detaylı açıklama yazın..." rows="8"
                          class="mt-2 w-full rounded-lg px-4 py-3 text-gray-900 placeholder-gray-400 focus:outline-none focus:ring-2 focus:ring-indigo-500 @(ViewData.ModelState["Content"]?.Errors.Count > 0 ? "border-red-500 ring-red-50" : "border border-gray-200")"
                          aria-invalid="@(ViewData.ModelState["Content"]?.Errors.Count > 0 ? "true" : "false")"></textarea>
                <span asp-validation-for="Content" class="text-sm text-red-600 mt-2 block"></span>
            </div>

            <div class="rounded-lg border border-indigo-100 bg-indigo-50 p-4">
                <p class="text-sm text-indigo-700 flex items-center gap-2">
                    <i class="fas fa-user-check"></i>
                    Yazar bilgisi giriş yapan hesaptan otomatik alınacaktır.
                </p>
            </div>

            <div class="flex flex-col sm:flex-row gap-3 sm:gap-4 pt-6 border-t border-gray-100">
                <button type="submit" class="flex-1 inline-flex justify-center items-center gap-2 bg-indigo-600 hover:bg-indigo-700 text-white font-semibold py-3 px-6 rounded-lg transition transform hover:-translate-y-0.5 shadow-sm">
                    <i class="fas fa-paper-plane"></i> Konuyu Paylaş
                </button>
                <a asp-controller="Forum" asp-action="Details" asp-route-id="@ViewBag.ForumId" class="flex-1 inline-flex justify-center items-center gap-2 bg-gray-100 hover:bg-gray-200 text-gray-800 font-medium py-3 px-6 rounded-lg transition">
                    <i class="fas fa-times"></i> İptal
                </a>
            </div>
        </form>
    </div>
</div>
