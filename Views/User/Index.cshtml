@model mym.Models.UserIndexViewModel
@{
    Layout = "_AdminLayout";
    ViewData["Title"] = "Kullanici Yonetimi";
    var vm = Model ?? new mym.Models.UserIndexViewModel();
    var users = vm.FilteredUsers ?? new List<mym.Models.AppUser>();
    var availableRoles = vm.AvailableRoles ?? new List<string>();
    var rolesByUserId = vm.RolesByUserId ?? new Dictionary<string, List<string>>();
}

<section class="space-y-6">
    <div class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
        <form asp-controller="User" asp-action="SetAutoApprove" method="post" class="flex flex-col gap-3 sm:flex-row sm:items-center sm:justify-between">
            @Html.AntiForgeryToken()
            <div>
                <h2 class="text-base font-semibold text-slate-900">Otomatik Kayit Onayi</h2>
                <p class="text-sm text-slate-500">Acik olursa yeni kullanicilar admin onayi beklemeden aktif olur.</p>
            </div>
            <label class="inline-flex cursor-pointer items-center gap-3">
                <input type="checkbox" name="enabled" value="true" @(Model?.AutoApproveNewUsers == true ? "checked" : null) class="peer sr-only" />
                <input type="hidden" name="enabled" value="false" />
                <div class="relative h-6 w-11 rounded-full bg-slate-300 transition peer-checked:bg-emerald-500"></div>
                <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-medium text-white hover:bg-slate-700 transition">
                    Kaydet
                </button>
            </label>
        </form>
    </div>

    <div class="grid gap-4 sm:grid-cols-2 lg:grid-cols-4">
        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm text-slate-500">Toplam</p>
            <p class="mt-1 text-3xl font-bold text-slate-900">@vm.TotalCount</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm text-slate-500">Aktif</p>
            <p class="mt-1 text-3xl font-bold text-emerald-600">@vm.ActiveCount</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm text-slate-500">Engelli</p>
            <p class="mt-1 text-3xl font-bold text-rose-600">@vm.BlockedCount</p>
        </article>
        <article class="rounded-2xl border border-slate-200 bg-white p-5 shadow-sm">
            <p class="text-sm text-slate-500">Onay Bekleyen</p>
            <p class="mt-1 text-3xl font-bold text-amber-600">@vm.PendingCount</p>
        </article>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 p-4 sm:p-5 space-y-3">
            <div class="flex flex-col gap-3 lg:flex-row lg:items-center lg:justify-between">
                <h2 class="text-lg font-semibold text-slate-900">Kullanici Listesi</h2>
                <button type="button" id="open-create-modal" class="inline-flex items-center rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white transition hover:bg-indigo-700">
                    Kullanici Ekle
                </button>
            </div>

            <form asp-controller="User" asp-action="Index" method="get" class="grid gap-3 md:grid-cols-4">
                <input type="text" name="search" value="@vm.Search" placeholder="Kullanici adi veya email"
                       class="rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100" />

                <select name="status" class="rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100">
                    <option value="all" selected="@(vm.StatusFilter == "all")">Tum Durumlar</option>
                    <option value="active" selected="@(vm.StatusFilter == "active")">Aktif</option>
                    <option value="passive" selected="@(vm.StatusFilter == "passive")">Pasif</option>
                    <option value="blocked" selected="@(vm.StatusFilter == "blocked")">Engelli</option>
                    <option value="pending" selected="@(vm.StatusFilter == "pending")">Onay Bekleyen</option>
                </select>

                <select name="role" class="rounded-lg border border-slate-300 px-3 py-2 text-sm outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100">
                    <option value="all" selected="@(vm.RoleFilter == "all")">Tum Roller</option>
                    @foreach (var roleName in availableRoles)
                    {
                        <option value="@roleName" selected="@(string.Equals(vm.RoleFilter, roleName, StringComparison.OrdinalIgnoreCase))">@roleName</option>
                    }
                </select>

                <button type="submit" class="rounded-lg bg-slate-900 px-4 py-2 text-sm font-semibold text-white transition hover:bg-slate-700">Filtrele</button>
            </form>
        </div>

        @if (!users.Any())
        {
            <div class="p-6">
                <div class="rounded-xl border border-amber-200 bg-amber-50 p-4 text-amber-800">
                    Filtreye uygun kullanici bulunamadi.
                </div>
            </div>
        }
        else
        {
            <div class="overflow-x-auto">
                <table class="min-w-full text-left text-sm">
                    <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                        <tr>
                            <th class="px-4 py-3">Kullanici</th>
                            <th class="px-4 py-3">Email</th>
                            <th class="px-4 py-3">Roller</th>
                            <th class="px-4 py-3">Durum</th>
                            <th class="px-4 py-3">Islemler</th>
                        </tr>
                    </thead>
                    <tbody class="divide-y divide-slate-100">
                        @foreach (var user in users)
                        {
                            rolesByUserId.TryGetValue(user.Id, out var assignedRoles);
                            assignedRoles ??= new List<string>();
                            var assignedRoleText = assignedRoles.Any() ? string.Join(", ", assignedRoles) : "Rol yok";
                            var selectedRole = assignedRoles.FirstOrDefault() ?? string.Empty;
                            var statusText = user.IsBlocked
                                ? "Engelli"
                                : user.IsActive
                                    ? "Aktif"
                                    : "Pasif";
                            var statusClass = user.IsBlocked
                                ? "bg-rose-100 text-rose-700"
                                : user.IsActive
                                    ? "bg-emerald-100 text-emerald-700"
                                    : "bg-slate-200 text-slate-700";
                            <tr class="hover:bg-slate-50">
                                <td class="px-4 py-3 font-medium text-slate-900">@user.UserName</td>
                                <td class="px-4 py-3 text-slate-600">@user.Email</td>
                                <td class="px-4 py-3 text-slate-700">
                                    <div class="space-y-2">
                                        <span>@assignedRoleText</span>
                                        <form asp-controller="User" asp-action="AssignRole" method="post" class="flex items-center gap-2">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <select name="roleName" class="w-40 rounded-lg border border-slate-300 bg-white px-2 py-1.5 text-sm text-slate-700 outline-none transition focus:border-cyan-500 focus:ring-2 focus:ring-cyan-100">
                                                <option value="">Rol sec</option>
                                                @foreach (var roleName in availableRoles)
                                                {
                                                    if (string.Equals(roleName, selectedRole, StringComparison.OrdinalIgnoreCase))
                                                    {
                                                        <option value="@roleName" selected>@roleName</option>
                                                    }
                                                    else
                                                    {
                                                        <option value="@roleName">@roleName</option>
                                                    }
                                                }
                                            </select>
                                            <button type="submit" class="rounded-lg bg-indigo-600 px-3 py-1.5 text-xs font-semibold text-white transition hover:bg-indigo-700">Ver</button>
                                        </form>
                                    </div>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="space-y-2">
                                        <span class="inline-flex items-center rounded-full px-2.5 py-1 text-xs font-semibold @statusClass">@statusText</span>
                                        <div class="text-xs text-slate-500">Onay: @(user.EmailConfirmed ? "Evet" : "Hayir")</div>
                                    </div>
                                </td>
                                <td class="px-4 py-3">
                                    <div class="flex flex-wrap gap-2">
                                        <button type="button"
                                                class="edit-user-btn rounded-lg border border-slate-300 px-3 py-1.5 text-xs font-semibold text-slate-700 hover:bg-slate-100"
                                                data-id="@user.Id"
                                                data-username="@user.UserName"
                                                data-email="@user.Email"
                                                data-is-active="@user.IsActive"
                                                data-is-blocked="@user.IsBlocked"
                                                data-email-confirmed="@user.EmailConfirmed">
                                            Duzenle
                                        </button>

                                        <form asp-controller="User" asp-action="ToggleActive" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="rounded-lg bg-slate-800 px-3 py-1.5 text-xs font-semibold text-white hover:bg-slate-700">Aktif/Pasif</button>
                                        </form>

                                        <form asp-controller="User" asp-action="ToggleBlock" method="post" class="inline">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="rounded-lg bg-amber-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-amber-700">Engel</button>
                                        </form>

                                        <form asp-controller="User" asp-action="DeleteUser" method="post" class="inline" onsubmit="return confirm('Bu kullanici silinsin mi?');">
                                            @Html.AntiForgeryToken()
                                            <input type="hidden" name="id" value="@user.Id" />
                                            <button type="submit" class="rounded-lg bg-rose-600 px-3 py-1.5 text-xs font-semibold text-white hover:bg-rose-700">Sil</button>
                                        </form>
                                    </div>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm">
        <div class="border-b border-slate-200 p-4 sm:p-5">
            <h2 class="text-lg font-semibold text-slate-900">Oturum ve Giris Gecmisi</h2>
        </div>
        <div class="overflow-x-auto">
            <table class="min-w-full text-left text-sm">
                <thead class="bg-slate-50 text-xs uppercase tracking-wide text-slate-500">
                    <tr>
                        <th class="px-4 py-3">Tarih</th>
                        <th class="px-4 py-3">Kullanici</th>
                        <th class="px-4 py-3">Durum</th>
                        <th class="px-4 py-3">IP</th>
                        <th class="px-4 py-3">Aciklama</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var item in vm.LoginActivities)
                    {
                        <tr>
                            <td class="px-4 py-3 text-slate-600">@item.CreatedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</td>
                            <td class="px-4 py-3 text-slate-800">@item.Username</td>
                            <td class="px-4 py-3">
                                @if (item.IsSuccess)
                                {
                                    <span class="inline-flex items-center rounded-full bg-emerald-100 px-2.5 py-1 text-xs font-semibold text-emerald-700">Basarili</span>
                                }
                                else
                                {
                                    <span class="inline-flex items-center rounded-full bg-rose-100 px-2.5 py-1 text-xs font-semibold text-rose-700">Basarisiz</span>
                                }
                            </td>
                            <td class="px-4 py-3 text-slate-600">@item.IpAddress</td>
                            <td class="px-4 py-3 text-slate-600">@item.Description</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</section>

<div id="create-user-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/60 p-4">
    <div class="w-full max-w-xl rounded-2xl bg-white p-6 shadow-xl">
        <h3 class="text-lg font-semibold text-slate-900">Yeni Kullanici Ekle</h3>
        <form asp-controller="User" asp-action="CreateUser" method="post" class="mt-4 grid gap-3 md:grid-cols-2">
            @Html.AntiForgeryToken()
            <input name="Username" required placeholder="Kullanici adi" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <input type="email" name="Email" required placeholder="E-posta" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <input type="password" name="Password" required placeholder="Sifre" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <label class="inline-flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="IsActive" value="true" checked /> Aktif</label>
            <label class="inline-flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="EmailConfirmed" value="true" checked /> Onayli</label>
            <input type="hidden" name="IsActive" value="false" />
            <input type="hidden" name="EmailConfirmed" value="false" />
            <div class="md:col-span-2 flex gap-2">
                <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Kaydet</button>
                <button type="button" id="close-create-modal" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Vazgec</button>
            </div>
        </form>
    </div>
</div>

<div id="edit-user-modal" class="fixed inset-0 z-50 hidden items-center justify-center bg-slate-900/60 p-4">
    <div class="w-full max-w-xl rounded-2xl bg-white p-6 shadow-xl">
        <h3 class="text-lg font-semibold text-slate-900">Kullanici Duzenle</h3>
        <form asp-controller="User" asp-action="EditUser" method="post" class="mt-4 grid gap-3 md:grid-cols-2">
            @Html.AntiForgeryToken()
            <input type="hidden" name="Id" id="edit-id" />
            <input name="Username" id="edit-username" required placeholder="Kullanici adi" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />
            <input type="email" name="Email" id="edit-email" required placeholder="E-posta" class="rounded-lg border border-slate-300 px-3 py-2 text-sm" />

            <label class="inline-flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="IsActive" id="edit-is-active" value="true" /> Aktif</label>
            <label class="inline-flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="IsBlocked" id="edit-is-blocked" value="true" /> Engelli</label>
            <label class="inline-flex items-center gap-2 text-sm text-slate-700"><input type="checkbox" name="EmailConfirmed" id="edit-email-confirmed" value="true" /> Onayli</label>
            <input type="hidden" name="IsActive" value="false" />
            <input type="hidden" name="IsBlocked" value="false" />
            <input type="hidden" name="EmailConfirmed" value="false" />

            <div class="md:col-span-2 flex gap-2">
                <button type="submit" class="rounded-lg bg-indigo-600 px-4 py-2 text-sm font-semibold text-white hover:bg-indigo-700">Guncelle</button>
                <button type="button" id="close-edit-modal" class="rounded-lg border border-slate-300 px-4 py-2 text-sm font-medium text-slate-700 hover:bg-slate-50">Vazgec</button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    <script>
        (function () {
            const createModal = document.getElementById("create-user-modal");
            const editModal = document.getElementById("edit-user-modal");
            const openCreateBtn = document.getElementById("open-create-modal");
            const closeCreateBtn = document.getElementById("close-create-modal");
            const closeEditBtn = document.getElementById("close-edit-modal");

            function openModal(modal) {
                modal.classList.remove("hidden");
                modal.classList.add("flex");
            }

            function closeModal(modal) {
                modal.classList.remove("flex");
                modal.classList.add("hidden");
            }

            if (openCreateBtn && createModal) {
                openCreateBtn.addEventListener("click", function () { openModal(createModal); });
            }

            if (closeCreateBtn && createModal) {
                closeCreateBtn.addEventListener("click", function () { closeModal(createModal); });
            }

            if (closeEditBtn && editModal) {
                closeEditBtn.addEventListener("click", function () { closeModal(editModal); });
            }

            document.querySelectorAll(".edit-user-btn").forEach(function (btn) {
                btn.addEventListener("click", function () {
                    document.getElementById("edit-id").value = btn.getAttribute("data-id") || "";
                    document.getElementById("edit-username").value = btn.getAttribute("data-username") || "";
                    document.getElementById("edit-email").value = btn.getAttribute("data-email") || "";
                    document.getElementById("edit-is-active").checked = (btn.getAttribute("data-is-active") || "").toLowerCase() === "true";
                    document.getElementById("edit-is-blocked").checked = (btn.getAttribute("data-is-blocked") || "").toLowerCase() === "true";
                    document.getElementById("edit-email-confirmed").checked = (btn.getAttribute("data-email-confirmed") || "").toLowerCase() === "true";
                    openModal(editModal);
                });
            });

            [createModal, editModal].forEach(function (modal) {
                if (!modal) return;
                modal.addEventListener("click", function (e) {
                    if (e.target === modal) {
                        closeModal(modal);
                    }
                });
            });
        })();
    </script>
}
