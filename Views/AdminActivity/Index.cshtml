@model mym.Models.Admin.UserActivityIndexViewModel
@{
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
    ViewData["Title"] = "Kullanıcı Aktivite";
}

<div class="w-full">
    <div class="mb-6 flex items-center justify-between">
        <div>
            <h1 class="text-2xl font-semibold text-slate-900">Kullanıcı Aktivite</h1>
            <p class="mt-1 text-sm text-slate-500">Aktif kullanıcı sayısı ve kullanıcıların son aktivitelerini görüntüleyin.</p>
        </div>
        <div class="text-right">
            <div class="text-sm text-slate-600">Toplam kullanıcı: <strong class="text-slate-900">@Model.TotalUsers</strong></div>
            <div class="text-sm text-emerald-600">Aktif (30dk): <strong>@Model.ActiveUserCount</strong></div>
        </div>
    </div>

    <div class="rounded-2xl border border-slate-200 bg-white shadow-sm overflow-hidden">
        <div class="overflow-x-auto">
            <table class="min-w-full divide-y divide-slate-200">
                <thead class="bg-slate-50">
                    <tr>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500">Kullanıcı</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500">E-posta</th>
                        <th class="px-4 py-3 text-center text-xs font-medium text-slate-500">Konu</th>
                        <th class="px-4 py-3 text-center text-xs font-medium text-slate-500">Yorum</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500">Son Giriş</th>
                        <th class="px-4 py-3 text-left text-xs font-medium text-slate-500">Son Aktivite</th>
                    </tr>
                </thead>
                <tbody class="divide-y divide-slate-100">
                    @foreach (var u in Model.Users)
                    {
                        <tr class="hover:bg-slate-50">
                            <td class="px-4 py-3">
                                <div class="flex items-center gap-3">
                                    <div class="h-8 w-8 flex-none rounded-full bg-slate-200 text-sm font-medium text-slate-700 flex items-center justify-center">@(!string.IsNullOrEmpty(u.Username) ? u.Username.Substring(0,1).ToUpper() : "?")</div>
                                    <div>
                                        <div class="text-sm font-medium text-slate-900">@u.Username</div>
                                        <div class="text-xs text-slate-400">@u.UserId</div>
                                    </div>
                                </div>
                            </td>
                            <td class="px-4 py-3 text-sm text-slate-700">@u.Email</td>
                            <td class="px-4 py-3 text-center text-sm text-slate-700">@u.TopicCount</td>
                            <td class="px-4 py-3 text-center text-sm text-slate-700">@u.CommentCount</td>
                            <td class="px-4 py-3 text-sm text-slate-700">@((u.LastLoginUtc.HasValue) ? u.LastLoginUtc.Value.ToLocalTime().ToString("g") : "-")</td>
                            <td class="px-4 py-3 text-sm text-slate-700">@u.LastActivityDescription</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>
    </div>
</div>
