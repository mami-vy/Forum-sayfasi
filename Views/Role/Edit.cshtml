@using mym.Models
@model RoleEditModel

@{
    ViewData["Title"] = "Yeni Rol Tanımlama";
}

<div class="max-w-2xl mx-auto mt-12 bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
    
    <div class="bg-indigo-50 px-8 py-6 border-b border-indigo-100">
        <h2 class="text-2xl font-bold text-indigo-900 tracking-tight">Sisteme Rol Düzenle</h2>
        <p class="text-sm text-indigo-700 mt-2">Lütfen aşağıdaki form aracılığıyla yetki grubunun detaylarını eksiksiz doldurunuz.</p>
    </div>

    <div class="px-8 py-8">
        <form asp-action="Edit" method="post" class="space-y-6">
            
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded-md hidden"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                <input type="hidden" name="Id" value="@Model.Id" />
                <div class="md:col-span-2">
                    <label asp-for="Name" class="block text-sm font-semibold text-gray-700 mb-1"></label>
                    <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow duration-200 sm:text-sm" placeholder="Örn: SuperAdmin, Moderator" />
                    <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="DisplayName" class="block text-sm font-semibold text-gray-700 mb-1"></label>
                    <input asp-for="DisplayName" class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow duration-200 sm:text-sm" placeholder="Forumda görünecek isim" />
                    <span asp-validation-for="DisplayName" class="text-xs text-red-500 mt-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-1"></label>
                    <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow duration-200 sm:text-sm" placeholder="isim@sirket.com" />
                    <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block font-medium"></span>
                </div>

               

            <div class="pt-6 border-t border-gray-100 flex items-center justify-end space-x-4">
                <a asp-action="Index" 
                class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                    İptal ve Geri Dön
                </a>
                <button type="submit" 
                        class="inline-flex items-center justify-center px-6 py-2.5 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-lg shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                    <svg class="w-4 h-4 mr-2" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path>
                    </svg>
                    Rolü Kaydet
                </button>
            </div>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}