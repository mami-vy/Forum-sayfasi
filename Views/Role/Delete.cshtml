@model mym.Models.AppRole

@{
    ViewData["Title"] = "Rolu Sil";
    Layout = "_AdminLayout";
}

<div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 py-10">
    <div class="rounded-xl border border-red-200 bg-white shadow-md overflow-hidden">
        <div class="bg-red-600 px-6 py-5 text-white">
            <h1 class="text-2xl font-bold">Rol Silme Onayi</h1>
            <p class="text-red-100 text-sm mt-1">Bu islem geri alinamaz.</p>
        </div>

        <div class="px-6 py-6 space-y-5">
            <div class="rounded-lg border border-red-100 bg-red-50 p-4 text-red-800">
                <p class="font-semibold">Bu rolu silmek istediginize emin misiniz?</p>
                <p class="text-sm mt-1">Role bagli yetkiler bu islemden etkilenebilir.</p>
            </div>

            <div class="rounded-lg border border-gray-200 p-4">
                <dl class="space-y-3">
                    <div>
                        <dt class="text-xs uppercase tracking-wide text-gray-500 font-semibold">Rol Adi</dt>
                        <dd class="text-lg font-bold text-gray-900">@Model.Name</dd>
                    </div>
                    <div>
                        <dt class="text-xs uppercase tracking-wide text-gray-500 font-semibold">Sistem Id</dt>
                        <dd class="font-mono text-sm text-gray-700 break-all">@Model.Id</dd>
                    </div>
                </dl>
            </div>

            <form asp-action="Delete" method="post" class="flex flex-wrap items-center gap-3">
                @Html.AntiForgeryToken()
                <input type="hidden" asp-for="Id" />

                <button type="submit"
                        class="inline-flex items-center px-5 py-2.5 rounded-lg bg-red-600 hover:bg-red-700 text-white font-semibold transition-colors duration-200">
                    Evet, Rolu Sil
                </button>

                <a asp-action="Index"
                   class="inline-flex items-center px-5 py-2.5 rounded-lg bg-gray-200 hover:bg-gray-300 text-gray-800 font-semibold transition-colors duration-200">
                    Vazgec
                </a>
            </form>
        </div>
    </div>
</div>
