@using mym.Models
@model RoleCreateModel

@{
    ViewData["Title"] = "Yeni Rol Tanımlama";
}

<div class="max-w-2xl mx-auto mt-12 bg-white rounded-xl shadow-lg border border-gray-100 overflow-hidden">
    
    <div class="bg-indigo-50 px-8 py-6 border-b border-indigo-100">
        <h2 class="text-2xl font-bold text-indigo-900 tracking-tight">Sisteme Yeni Rol Ekle</h2>
        <p class="text-sm text-indigo-700 mt-2">Lütfen aşağıdaki form aracılığıyla yetki grubunun detaylarını eksiksiz doldurunuz.</p>
    </div>

    <div class="px-8 py-8">
        <form asp-action="Create" method="post" class="space-y-6">
            
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-sm text-red-600 bg-red-50 p-3 rounded-md hidden"></div>

            <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
                
                <div class="md:col-span-2">
                    <label asp-for="Name" class="block text-sm font-semibold text-gray-700 mb-1"></label>
                    <input asp-for="Name" class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow duration-200 sm:text-sm" placeholder="Örn: SuperAdmin, Moderator" />
                    <span asp-validation-for="Name" class="text-xs text-red-500 mt-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="DisplayName" class="block text-sm font-semibold text-gray-700 mb-1"></label>
                    <input asp-for="DisplayName" class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow duration-200 sm:text-sm" placeholder="Forumda görünecek isim" />
                    <span asp-validation-for="DisplayName" class="text-xs text-red-500 mt-1 block font-medium"></span>
                </div>

                <div>
                    <label asp-for="Email" class="block text-sm font-semibold text-gray-700 mb-1"></label>
                    <input asp-for="Email" type="email" class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow duration-200 sm:text-sm" placeholder="isim@sirket.com" />
                    <span asp-validation-for="Email" class="text-xs text-red-500 mt-1 block font-medium"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="ProfileImageUrl" class="block text-sm font-semibold text-gray-700 mb-1">Profil Görsel Bağlantısı (URL)</label>
                    <div class="flex rounded-md shadow-sm">
                        <span class="inline-flex items-center px-3 rounded-l-lg border border-r-0 border-gray-300 bg-gray-50 text-gray-500 sm:text-sm">
                            https://
                        </span>
                        <input asp-for="ProfileImageUrl" class="flex-1 min-w-0 block w-full px-4 py-2 rounded-none rounded-r-lg border border-gray-300 focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow duration-200 sm:text-sm" placeholder="cdn.sirket.com/image.jpg" />
                    </div>
                    <span asp-validation-for="ProfileImageUrl" class="text-xs text-red-500 mt-1 block font-medium"></span>
                </div>

                <div class="md:col-span-2">
                    <label asp-for="Bio" class="block text-sm font-semibold text-gray-700 mb-1"></label>
                    <textarea asp-for="Bio" rows="4" class="w-full px-4 py-2 border border-gray-300 rounded-lg shadow-sm focus:ring-2 focus:ring-indigo-500 focus:border-indigo-500 transition-shadow duration-200 sm:text-sm resize-y" placeholder="Rolün veya bu role sahip kişinin detaylı açıklaması..."></textarea>
                    <span asp-validation-for="Bio" class="text-xs text-red-500 mt-1 block font-medium"></span>
                    <p class="text-xs text-gray-400 mt-2 text-right">Maksimum 500 karakter</p>
                </div>
            </div>

            <div class="pt-6 border-t border-gray-100 flex items-center justify-end space-x-4">
                <a asp-action="Index" class="px-5 py-2.5 text-sm font-medium text-gray-700 bg-white border border-gray-300 rounded-lg hover:bg-gray-50 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                    İptal ve Geri Dön
                </a>
                <button type="submit" class="inline-flex justify-center px-6 py-2.5 text-sm font-medium text-white bg-indigo-600 border border-transparent rounded-lg shadow-sm hover:bg-indigo-700 focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-indigo-500 transition-colors duration-200">
                    <svg class="w-5 h-5 mr-2 -ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M5 13l4 4L19 7"></path></svg>
                    Rolü Kaydet
                </button>
            </div>
        </form>
    </div>
</div>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}